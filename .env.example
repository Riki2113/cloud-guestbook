# ─────────────────────────────────────────────────────────
# Salin file ini menjadi .env untuk development lokal
# cp .env.example .env
# ─────────────────────────────────────────────────────────

# Environment: development | production
NODE_ENV=development

# Port server (Railway otomatis set ini di production)
PORT=3000

# URL koneksi PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Untuk Railway: copy dari dashboard > Variables > DATABASE_URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/guestbook
